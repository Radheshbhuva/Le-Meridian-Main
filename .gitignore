# =====================
# Root-level .gitignore
# =====================

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Editor directories
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Node
node_modules/

# Environment variables — NEVER commit secrets
.env
.env.*
!.env.example

# Temporary files
*.tmp
*.bak
*.swp
