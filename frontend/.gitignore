# ========================
# Frontend .gitignore
# ========================

# Dependencies
node_modules/

# Production build
build/
dist/

# Environment variables — NEVER commit secrets
.env
.env.*
.env.local
.env.development.local
.env.test.local
.env.production.local
!.env.example

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Create React App cache
.cache/
.eslintcache

# OS files
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/

# Testing
coverage/
